# =============================================================================
# Agent Skills Manager — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# macOS
# -----------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# -----------------------------------------------------------------------------
# Windows
# -----------------------------------------------------------------------------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# -----------------------------------------------------------------------------
# Linux
# -----------------------------------------------------------------------------
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# -----------------------------------------------------------------------------
# Editor & IDE
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.suo
*.user
*.userosscache
*.sln.docview
.vs/

# JetBrains Rider
.fleet/

# Vim
[._]*.s[a-w][a-z]
[._]s[a-w][a-z]
*.un~
Session.vim
.netrwhist

# -----------------------------------------------------------------------------
# Rust
# -----------------------------------------------------------------------------
# Compiled output
target/
src-tauri/target/

# Incremental compilation
**/*.d
**/*.pdb

# Cargo lock for libraries (keep for binaries / apps)
# Cargo.lock  ← intentionally NOT ignored (this is an app)

# Generated by Tauri
src-tauri/gen/

# -----------------------------------------------------------------------------
# Node / Bun / Frontend
# -----------------------------------------------------------------------------
node_modules/
dist/
src-ui/dist/
.next/
out/

# Dependency lock files (keep bun.lock, ignore others)
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build cache
.parcel-cache/
.cache/
.turbo/

# TypeScript
*.tsbuildinfo

# Vite
.vite/

# -----------------------------------------------------------------------------
# Tauri
# -----------------------------------------------------------------------------
# Auto-generated capability files (re-generated on build)
src-tauri/capabilities/autogenerated/

# WiX toolset (Windows installer)
src-tauri/WixTools/

# Tauri bundle artifacts
src-tauri/target/release/bundle/

# -----------------------------------------------------------------------------
# AI Agent skill/config directories
# (These should not be committed into the project)
# -----------------------------------------------------------------------------
.agent/
.agents/
.claude/
.codebuddy/
.codex/
.gemini/
.iflow/
.opencode/
.playwright-cli/
.qoder/
.qwen/
.roo/
.trae/
.workbuddy/

# -----------------------------------------------------------------------------
# Logs & Debug
# -----------------------------------------------------------------------------
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
bun-debug.log*

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
coverage/
*.lcov
.nyc_output/
test-results/
playwright-report/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
*.pem
*.key
*.p12

# -----------------------------------------------------------------------------
# Misc build / output
# -----------------------------------------------------------------------------
*.out
data/
build/
