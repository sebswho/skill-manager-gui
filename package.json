{
  "name": "agent-skills-manager-ui",
  "private": true,
  "version": "0.1.0",
  "license": "LGPL-3.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "cd src-tauri && tauri",
    "tauri:dev": "cd src-tauri && tauri dev",
    "tauri:build": "cd src-tauri && tauri build",
    "bundle:mac": "cd src-tauri && tauri build --target universal-apple-darwin",
    "bundle:win": "cd src-tauri && tauri build --target x86_64-pc-windows-msvc",
    "bundle:linux": "cd src-tauri && tauri build --target x86_64-unknown-linux-gnu",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "check": "cargo test --manifest-path src-tauri/Cargo.toml && bunx vitest run && bun run build && bun run test:e2e"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-shell": "^2.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^3.5.0",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.0",
    "jsdom": "^29.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "vitest": "^4.1.0"
  }
}
